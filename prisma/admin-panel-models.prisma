model Customer {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String   // bcrypt hash
  name      String?
  surname   String?
  phone     String?
  country   String?
  city      String?
  gender    String?
  profilePicture String?
  emailVerified Boolean @default(false)
  createdAt DateTime @default(now())
  projects  Project[]
  verificationCodes VerificationCode[]
  passwordResetTokens PasswordResetToken[]
}

model Project {
  id          String    @id @default(cuid())
  customerId  String
  studyId     String
  name        String
  brand       String?
  sector      Sector
  city        String?
  currency    String
  capital     Decimal   @db.Decimal(12, 2)
  avgPrice    Decimal?  @db.Decimal(12, 2)
  paybackMonths Int?
  inputsConfirmed Boolean @default(false)
  foundingConfirmed Boolean @default(false)
  operatingConfirmed Boolean @default(false)
  salesConfirmed Boolean @default(false)
  stripeSessionId String? @unique
  paidAmount  Decimal?  @db.Decimal(12, 2)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  customer    Customer  @relation(fields: [customerId], references: [id])
  study       Study     @relation(fields: [studyId], references: [id], onDelete: Cascade)
  foundingExpenses   FoundingExpense[]
  operatingExpenses  OperatingExpense[]
  sales             Sale[]

  @@index([customerId])
  @@index([studyId])
}

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model AdminUser {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String   // bcrypt hash
  name      String?
  createdAt DateTime @default(now())

  @@map("admin_users")
}

enum Sector {
  FOOD
  INDUSTRIAL
  SERVICE
  COMMERCIAL
  TECH
  OTHER
}

enum StudyStatus {
  PUBLISHED
  COMING_SOON
  DRAFT
}

model Study {
  id                 String      @id @default(cuid())
  title              String
  coverImage         String?
  price              Decimal     @db.Decimal(10, 2)
  oldPrice           Decimal?    @db.Decimal(10, 2)
  shortDescription   String?
  sector             Sector
  status             StudyStatus @default(DRAFT)
  deliverables       String[]    @default([])
  fileUrl            String?     // downloadable file after purchase
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  projects           Project[]
  studyFoundingExpenses  StudyFoundingExpense[]
  studyOperatingExpenses StudyOperatingExpense[]
  studySales             StudySale[]

  @@map("studies")
}

model StudyFoundingExpense {
  id        String  @id @default(cuid())
  studyId   String
  name      String
  amount    Decimal @db.Decimal(12, 2)

  study     Study   @relation(fields: [studyId], references: [id], onDelete: Cascade)

  @@index([studyId])
  @@map("study_founding_expenses")
}

model StudyOperatingExpense {
  id        String  @id @default(cuid())
  studyId   String
  month     Int
  name      String
  amount    Decimal @db.Decimal(12, 2)

  study     Study   @relation(fields: [studyId], references: [id], onDelete: Cascade)

  @@index([studyId])
  @@map("study_operating_expenses")
}

model StudySale {
  id        String  @id @default(cuid())
  studyId   String
  month     Int
  amount    Decimal @db.Decimal(12, 2)

  study     Study   @relation(fields: [studyId], references: [id], onDelete: Cascade)

  @@index([studyId])
  @@map("study_sales")
}

enum ContactStatus {
  NEW
  REPLIED
  CLOSED
}

model Contact {
  id        String        @id @default(cuid())
  fullName  String
  email     String
  phone     String?
  country   String?
  message   String
  status    ContactStatus @default(NEW)
  createdAt DateTime      @default(now())

  @@map("contacts")
}

enum EventType {
  PAGE_VIEW
  BUTTON_CLICK
}

model AnalyticsEvent {
  id        String    @id @default(cuid())
  eventType EventType
  page      String
  element   String?   // button name, null for page views
  country   String?
  source    String?   // referrer / utm source
  createdAt DateTime  @default(now())

  @@map("analytics_events")
}
